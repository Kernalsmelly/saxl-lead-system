# Copy to .env.local and fill in from Supabase dashboard → Project Settings → API.
# .env.local is gitignored; this file is the source of truth for required env vars.

# Public URL of this app. Used to build magic-link redirect URLs.
# Local dev: http://localhost:3000. Production: the Vercel URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...). Browser-safe. Subject to RLS.
# Supersedes the legacy "anon" key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...). Server-only; bypasses RLS.
# Used by webhooks, cron jobs, and admin operations. NEVER expose to the browser.
# Supersedes the legacy "service_role" key.
SUPABASE_SECRET_KEY=
