# Copy to .env.local and fill in from Supabase dashboard → Project Settings → API.
# .env.local is gitignored; this file is the source of truth for required env vars.

# Public URL of this app. Used to build magic-link redirect URLs.
# Local dev: http://localhost:3000. Production: the Vercel URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side base URL used in outbound notifications (e.g. the
# "View lead details" link in owner emails). Often the same as
# NEXT_PUBLIC_APP_URL but kept separate so we can point notifications
# at a stable canonical URL even when previews exist.
APP_BASE_URL=http://localhost:3000

# Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...). Browser-safe. Subject to RLS.
# Supersedes the legacy "anon" key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...). Server-only; bypasses RLS.
# Used by webhooks, cron jobs, and admin operations. NEVER expose to the browser.
# Supersedes the legacy "service_role" key.
SUPABASE_SECRET_KEY=

# Resend API key (re_...). Server-only. Used to send owner notifications
# when new leads arrive. Get one at https://resend.com/api-keys.
RESEND_API_KEY=

# From-address for outbound notifications. Must be a sender on a domain
# verified in Resend. Default value below is the v1 single sender;
# per-tenant senders are deferred to v2.
NOTIFICATIONS_FROM_EMAIL=notifications@saxllabs.com
